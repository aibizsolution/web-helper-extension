{
  "manifest_version": 3,
  "name": "웹 도우미",
  "version": "2.4.2",
  "description": "웹 번역, 텍스트 번역, 검색, SEO·AI 노출 진단을 돕는 확장프로그램",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "tabs",
    "contextMenus",
    "history",
    "browsingData"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "optional_host_permissions": [
    "file:///*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "modules/*.js"
      ],
      "matches": [
        "https://*/*",
        "http://*/*"
      ]
    }
  ],
  "action": {
    "default_title": "웹 도우미",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "웹 도우미 사이드패널 열기"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
